# Rust build artifacts
target/
**/*.rs.bk
*.pdb

# Cargo lock file (for applications, keep it; for libraries, ignore it)
# We'll keep it for the binary application
# Cargo.lock

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test fixtures (can be regenerated)
convx-core/tests/fixtures/*
!convx-core/tests/fixtures/.gitkeep

# Temporary files
*.tmp
*.temp
.scratch/

# Node modules (for future Quasar frontend)
node_modules/
dist/
.quasar/
.nuxt/

# Environment files
.env
.env.local
.env.*.local

# OS generated files
Thumbs.db
.Spotlight-V100
.Trashes

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
*.exe
*.dll
*.so
*.dylib
!.gitkeep

# Tauri
**/src-tauri/target/
**/src-tauri/gen/

# Claude Code local settings
.claude/settings.local.json

# Wrangler local state
license-server/.wrangler/
